#!/bin/zsh
set -euo pipefail

repo_root=${0:A:h:h}
cd "$repo_root"

article=howto/ai-survivors-terminal-render-capture.md
[[ -f "$article" ]]
for required in \
  "scripts/check-toolchain" \
  "scripts/build-capture" \
  ".build/bin/terminal-render-capture self-test" \
  "scripts/terminal-render-capture capture" \
  "glyph_atlas" \
  "baseline-update" \
  "Ghostty" \
  "Terminal.app"; do
  /usr/bin/grep -F "$required" "$article" >/dev/null
done

scripts/check-toolchain
scripts/build-capture
.build/bin/terminal-render-capture self-test

scratch="$repo_root/.build/documentation-smoke"
/bin/mkdir -p "$scratch"
.build/bin/terminal-render-capture capture \
  --artifact "$scratch/unused.json" \
  --direct --cols 100 --rows 20 \
  -- /usr/bin/ssh 2>/dev/null && exit 1
capture_status=$?
[[ "$capture_status" -eq 4 ]]

echo "documentation smoke passed"
